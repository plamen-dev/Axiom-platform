{
  "_comment": "Planned test cases for CreateLevels capability. Do not run until implementation is complete.",
  "test_cases": [
    {
      "test_id": "uniform_5_levels_12ft",
      "prompt": "Create 5 levels at 12 ft floor-to-floor",
      "expected_capability": "CreateLevels",
      "expected_parameters": {
        "LevelCount": 5,
        "FloorToFloorFeet": 12.0,
        "StartElevationFeet": 0.0
      },
      "expected_created_count": 5,
      "expected_success": true,
      "mode": "simulate",
      "notes": "Baseline uniform level creation"
    },
    {
      "test_id": "uniform_3_levels_10ft",
      "prompt": "Create 3 levels spaced 10 feet apart",
      "expected_capability": "CreateLevels",
      "expected_parameters": {
        "LevelCount": 3,
        "FloorToFloorFeet": 10.0,
        "StartElevationFeet": 0.0
      },
      "expected_created_count": 3,
      "expected_success": true,
      "mode": "simulate",
      "notes": "Uniform levels using 'spaced apart' phrasing"
    },
    {
      "test_id": "uniform_1_level",
      "prompt": "Create 1 level at 0 feet",
