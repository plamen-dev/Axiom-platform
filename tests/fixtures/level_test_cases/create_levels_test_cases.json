      "prompt": "Create levels:\n  Basement = -10'\n  Ground = 0'\n  Level 2 = 12'\n  Level 3 = 24'\n  Roof = 36'",
      "expected_capability": "CreateLevels",
      "expected_parameters": {
        "LevelCount": 5,
        "LevelNames": ["Basement", "Ground", "Level 2", "Level 3", "Roof"],
